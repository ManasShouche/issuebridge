# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ── Slack (Socket Mode) ────────────────────────────────────────────────────────
SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN       # xapp-...
SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN       # xoxb-...

# User token for legacy search.messages fallback (dev only, needs search:read)
# SLACK_USER_TOKEN=YOUR_SLACK_USER_TOKEN

# ── Slack Real-Time Search API (replace fallback before submission) ────────────
# SLACK_RTS_ENDPOINT=https://...             # from hackathon Resources page
# SLACK_RTS_TOKEN=YOUR_SLACK_RTS_TOKEN       # if different from BOT_TOKEN

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=YOUR_GITHUB_PAT               # classic PAT, repo + public_repo scopes
FORK_REPO=yourname/vllm                    # your fork of vllm-project/vllm

# ── IssueBridge config ────────────────────────────────────────────────────────
MAINTAINERS_CHANNEL=maintainers            # channel where triage cards are posted

# Channel ID overrides — required on Enterprise Grid (conversations.list is blocked)
# Get IDs: right-click any channel in Slack → Copy link → URL has /archives/C12345
# HELP_CHANNEL_ID=C...
# GENERAL_CHANNEL_ID=C...
# MAINTAINERS_CHANNEL_ID=C...

# GitHub MCP server (optional — leave unset to use REST fallback)
# GITHUB_MCP_URL=http://localhost:8080      # local Docker: github/github-mcp-server

# ── Slack OAuth (app_oauth.py only) ───────────────────────────────────────────
# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect

# Optional: custom Slack API base URL (enterprise/custom instances)
# SLACK_API_URL=YOUR_SLACK_API_URL
